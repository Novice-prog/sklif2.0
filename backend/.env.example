DATABASE_URL=postgresql+psycopg2://clinical_user:clinical_pass@localhost:55432/clinical_data
APP_NAME=Clinical Data API
APP_ENV=development
API_V1_PREFIX=/api/v1
API_BEARER_TOKEN=
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=60
ALLOW_INSECURE_DEV_AUTH=false
BOOTSTRAP_ADMIN_LOGIN=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Администратор системы
BOOTSTRAP_ADMIN_ROLE=admin
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
